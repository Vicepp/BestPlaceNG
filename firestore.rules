rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // --- Curated research data: cities, cost-of-living, crime, climate ---
    // Public read (the whole site depends on it), write only from the Firebase
    // console or an authenticated admin script - never from the browser.
    match /cities/{slug} {
      allow read: if true;
      allow write: if false;
    }
    match /costOfLivingResearch/{slug} {
      allow read: if true;
      allow write: if false;
    }
    match /crimeResearch/{slug} {
      allow read: if true;
      allow write: if false;
    }
    match /climateNormals/{slug} {
      allow read: if true;
      allow write: if false;
    }
    match /config/{doc} {
      allow read: if true;
      allow write: if false;
    }

    // State-level civic data (elections, religion split) — public read, edited
    // only via the console/seed script.
    match /stateInsights/{stateSlug} {
      allow read: if true;
      allow write: if false;
    }

    // Private KYC details (NIN, ID documents) — ONLY the owner can read/write.
    // Never expose these publicly; the users doc carries only a status flag.
    match /kyc/{uid} {
      allow read, create, update: if request.auth != null && request.auth.uid == uid;
      allow delete: if false;
    }

    // Support tickets from the dashboard contact form.
    match /supportTickets/{id} {
      allow read: if request.auth != null && resource.data.userId == request.auth.uid;
      allow create: if request.auth != null
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.message is string
        && request.resource.data.message.size() > 0
        && request.resource.data.message.size() < 5000;
      allow update, delete: if false;
    }

    // Reviews about a user (by the other party of a tenancy/tour).
    match /userReviews/{id} {
      allow read: if true;
      allow create: if request.auth != null
        && request.resource.data.reviewerId == request.auth.uid
        && request.resource.data.reviewerId != request.resource.data.subjectId
        && request.resource.data.rating is int
        && request.resource.data.rating >= 1
        && request.resource.data.rating <= 5
        && request.resource.data.comment is string
        && request.resource.data.comment.size() > 0
        && request.resource.data.comment.size() < 2000;
      allow update, delete: if false;
    }

    // Append-only research snapshots (written by scripts/append-research.mjs via
    // the Admin SDK only). Public read; clients can never write or overwrite.
    match /cityResearch/{id} {
      allow read: if true;
      allow write: if false;
    }
    match /stateResearch/{id} {
      allow read: if true;
      allow write: if false;
    }
    match /notableIncidents/{id} {
      allow read: if true;
      allow write: if false;
    }

    // --- User-generated content ---
    // Anyone can read listings; only signed-in users can create one, and only
    // the original poster (or no one, for now, until a moderation flow exists)
    // can edit/delete it.
    match /apartments/{id} {
      allow read: if true;
      allow create: if request.auth != null
        && request.resource.data.ownerId == request.auth.uid
        && request.resource.data.priceNaira is number
        && request.resource.data.priceNaira > 0;
      allow update, delete: if request.auth != null && resource.data.ownerId == request.auth.uid;
    }
    match /directoryListings/{id} {
      allow read: if true;
      allow create: if request.auth != null && request.resource.data.ownerId == request.auth.uid;
      allow update, delete: if request.auth != null && resource.data.ownerId == request.auth.uid;
    }

    // Reviews: open posting (no login required, matches the original
    // localStorage-based UX) but field-validated to prevent garbage data.
    match /reviews/{id} {
      allow read: if true;
      allow create: if request.resource.data.rating is int
        && request.resource.data.rating >= 1
        && request.resource.data.rating <= 5
        && request.resource.data.name is string
        && request.resource.data.name.size() > 0
        && request.resource.data.name.size() < 100
        && request.resource.data.comment is string
        && request.resource.data.comment.size() > 0
        && request.resource.data.comment.size() < 2000;
      // Public like/dislike: only those two counters may change, each can only
      // go up, and by at most 1 per write (no wiping or bulk-inflating counts).
      allow update: if request.resource.data.diff(resource.data).affectedKeys().hasOnly(["likes", "dislikes"])
        && request.resource.data.get("likes", 0) is int
        && request.resource.data.get("dislikes", 0) is int
        && request.resource.data.get("likes", 0) >= resource.data.get("likes", 0)
        && request.resource.data.get("likes", 0) <= resource.data.get("likes", 0) + 1
        && request.resource.data.get("dislikes", 0) >= resource.data.get("dislikes", 0)
        && request.resource.data.get("dislikes", 0) <= resource.data.get("dislikes", 0) + 1;
      allow delete: if false;
    }

    // Public replies to reviews — same open-but-size-limited stance as reviews.
    match /reviewReplies/{id} {
      allow read: if true;
      allow create: if request.resource.data.reviewId is string
        && request.resource.data.name is string
        && request.resource.data.name.size() > 0
        && request.resource.data.name.size() < 100
        && request.resource.data.comment is string
        && request.resource.data.comment.size() > 0
        && request.resource.data.comment.size() < 2000;
      allow update, delete: if false;
    }

    // --- User accounts ---
    match /users/{uid} {
      allow read: if true;
      allow create, update: if request.auth != null && request.auth.uid == uid;
      allow delete: if false;
    }

    // --- Tenancies: links a tenant to one apartment ---
    // Two creation paths: landlord invites a tenant by email ("invited", tenantId
    // null until that email signs up), or a tenant requests to rent ("requested",
    // landlord approves/rejects). Note: the auto-link-on-signup branch trusts the
    // Auth token's self-reported email (no email-verification step exists yet) -
    // accepted tradeoff for v1, see project notes.
    match /tenancies/{tenancyId} {
      // A user can also read (and thus query for) a not-yet-linked invite
      // addressed to their own email - required for the auto-link-on-signup
      // flow to find its own pending invites before tenantId is set.
      allow read: if request.auth != null
        && (resource.data.landlordId == request.auth.uid
            || resource.data.tenantId == request.auth.uid
            || (resource.data.tenantId == null && resource.data.tenantEmail == request.auth.token.email));

      allow create: if request.auth != null && (
        (request.resource.data.landlordId == request.auth.uid
          && request.resource.data.status == "invited"
          && request.resource.data.tenantId == null
          && request.resource.data.tenantEmail is string
          && get(/databases/$(database)/documents/apartments/$(request.resource.data.apartmentId)).data.ownerId == request.auth.uid)
        ||
        (request.resource.data.tenantId == request.auth.uid
          && request.resource.data.status == "requested"
          && request.resource.data.landlordId == get(/databases/$(database)/documents/apartments/$(request.resource.data.apartmentId)).data.ownerId)
      );

      allow update: if request.auth != null && (
        (resource.data.landlordId == request.auth.uid
          && resource.data.status in ["requested", "invited"]
          && request.resource.data.status in ["active", "rejected"]
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(["status"]))
        ||
        (resource.data.status == "invited"
          && resource.data.tenantId == null
          && resource.data.tenantEmail == request.auth.token.email
          && request.resource.data.tenantId == request.auth.uid
          && request.resource.data.status == "active"
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(["tenantId", "status"]))
        ||
        // Landlord sets/updates the agreed move-in date (only that field).
        (resource.data.landlordId == request.auth.uid
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(["moveInDate"]))
        ||
        // Tenant confirms move-in — the trigger that releases escrowed rent.
        (resource.data.tenantId == request.auth.uid
          && request.resource.data.moveInConfirmed == true
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(["moveInConfirmed", "moveInConfirmedAt"]))
      );

      allow delete: if request.auth != null && resource.data.landlordId == request.auth.uid;
    }

    // --- Conversations: 1:1 and per-property group chats ---
    match /conversations/{conversationId} {
      allow read: if request.auth != null && request.auth.uid in resource.data.participantIds;
      allow create: if request.auth != null
        && request.auth.uid in request.resource.data.participantIds
        && request.resource.data.participantIds is list
        && request.resource.data.participantIds.size() >= 2;
      allow update: if request.auth != null && (
        // Existing participants can update (lastMessage bump, landlord adding tenants)
        (request.auth.uid in resource.data.participantIds
          && request.auth.uid in request.resource.data.participantIds)
        ||
        // Self-join: a newly-confirmed tenant adds ONLY themselves to the property
        // group chat (the auto-link flow runs as the tenant, who isn't a participant
        // yet). Must keep all existing members and add exactly one: self.
        (!(request.auth.uid in resource.data.participantIds)
          && request.auth.uid in request.resource.data.participantIds
          && request.resource.data.participantIds.hasAll(resource.data.participantIds)
          && request.resource.data.participantIds.size() == resource.data.participantIds.size() + 1)
      );
      allow delete: if false;

      match /messages/{messageId} {
        allow read: if request.auth != null
          && request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participantIds;
        allow create: if request.auth != null
          && request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participantIds
          && request.resource.data.senderId == request.auth.uid;
        allow update, delete: if false;
      }
    }

    // --- Maintenance tickets ---
    match /maintenanceTickets/{id} {
      allow read: if request.auth != null
        && (resource.data.landlordId == request.auth.uid || resource.data.tenantId == request.auth.uid);
      allow create: if request.auth != null && request.resource.data.tenantId == request.auth.uid;
      allow update: if request.auth != null
        && resource.data.landlordId == request.auth.uid
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(["status", "updatedAt"]);
      allow delete: if false;
    }

    // --- Properties (buildings/estates) ---
    match /properties/{id} {
      allow read: if true;
      allow create: if request.auth != null && request.resource.data.ownerId == request.auth.uid;
      allow update, delete: if request.auth != null && resource.data.ownerId == request.auth.uid;
    }

    // --- Notifications ---
    match /notifications/{id} {
      allow read: if request.auth != null && resource.data.userId == request.auth.uid;
      allow create: if request.auth != null;
      allow update: if request.auth != null && resource.data.userId == request.auth.uid;
      allow delete: if false;
    }

    // --- Utility fees (per-tenancy recurring charges set by landlord) ---
    match /utilityFees/{id} {
      allow read: if request.auth != null
        && (resource.data.landlordId == request.auth.uid || resource.data.tenantId == request.auth.uid);
      allow create: if request.auth != null && request.resource.data.landlordId == request.auth.uid;
      allow update: if request.auth != null && resource.data.landlordId == request.auth.uid
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(["status"]);
      allow delete: if false;
    }

    // --- Utility payment requests ---
    match /utilityPaymentRequests/{id} {
      allow read: if request.auth != null
        && (resource.data.landlordId == request.auth.uid || resource.data.tenantId == request.auth.uid);
      allow create: if request.auth != null && request.resource.data.landlordId == request.auth.uid;
      allow update: if request.auth != null
        && (resource.data.landlordId == request.auth.uid || resource.data.tenantId == request.auth.uid)
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(["status", "paidAt"]);
      allow delete: if false;
    }

    // --- AI chatbot training data (write-only log per user) ---
    match /chatTrainingData/{uid} {
      allow read: if false;
      allow write: if request.auth != null && request.auth.uid == uid;
    }

    // --- User chat threads (conversation history for the AI assistant) ---
    match /userChatThreads/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // --- Rent payments ---
    // Landlords create "pending" invoices for their own tenancies; status can
    // only ever flip to "success" via the admin-SDK-backed /api/payments/verify
    // route (which bypasses these rules entirely), never directly by a client -
    // that's what makes a "success" status trustworthy.
    match /payments/{paymentId} {
      allow read: if request.auth != null
        && (resource.data.landlordId == request.auth.uid || resource.data.tenantId == request.auth.uid);
      // Two create paths, both must be "pending" with a positive amount (only the
      // admin-SDK verify route can ever flip status to "success"):
      //  1. Landlord invoicing one of their own tenancies.
      //  2. Tenant self-invoicing on the Become-a-Tenant flow (paying to move in).
      allow create: if request.auth != null
        && request.resource.data.status == "pending"
        && request.resource.data.amount is number && request.resource.data.amount > 0
        && (
          (request.resource.data.landlordId == request.auth.uid
            && get(/databases/$(database)/documents/tenancies/$(request.resource.data.tenancyId)).data.landlordId == request.auth.uid
            && get(/databases/$(database)/documents/tenancies/$(request.resource.data.tenancyId)).data.tenantId == request.resource.data.tenantId)
          ||
          (request.resource.data.tenantId == request.auth.uid
            && get(/databases/$(database)/documents/tenancies/$(request.resource.data.tenancyId)).data.tenantId == request.auth.uid)
        );
      allow update: if false;
      allow delete: if false;
    }

    // --- Landlord wallet (rent proceeds held until withdrawal) ---
    // Money fields (balance/held/totalReceived/recipientCode) are ONLY changed
    // by the admin-SDK verify/release/withdraw routes. The landlord may read
    // their own wallet and may write ONLY their payout bank details.
    match /wallets/{uid} {
      allow read: if request.auth != null && request.auth.uid == uid;
      // First-time payout-details save (no money fields present).
      allow create: if request.auth != null && request.auth.uid == uid
        && request.resource.data.keys().hasOnly(["bank", "landlordId"]);
      // Later edits may only touch the payout bank details.
      allow update: if request.auth != null && request.auth.uid == uid
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(["bank", "landlordId"]);
    }

    // --- Withdrawals (payout log) — admin-written, landlord-readable ---
    match /withdrawals/{id} {
      allow read: if request.auth != null && resource.data.landlordId == request.auth.uid;
      allow write: if false;
    }

    // --- Property tour bookings ---
    // Any signed-in user may read (needed so prospective tenants see which slots
    // are already taken and can't double-book). A tenant creates their own
    // booking; either party may cancel (status only).
    match /tourBookings/{id} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.resource.data.tenantId == request.auth.uid;
      // Either party may cancel; the only fields a cancel may touch are the
      // status and (when the canceller gives one) the reason + timestamp.
      allow update: if request.auth != null
        && (resource.data.tenantId == request.auth.uid || resource.data.landlordId == request.auth.uid)
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(["status", "cancelReason", "cancelledAt"]);
      allow delete: if false;
    }

    // --- Reports / disputes to the admin ---
    // A tenant (or any signed-in user) files a report; only the platform admin
    // reads them (via the Firebase console). Reporter can read their own.
    match /reports/{id} {
      allow read: if request.auth != null && resource.data.reporterId == request.auth.uid;
      allow create: if request.auth != null && request.resource.data.reporterId == request.auth.uid;
      allow update, delete: if false;
    }
  }
}
